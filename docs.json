{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Openmoon Protocol",
  "description": "AI Agent Commerce Protocol on Solana. A marketplace where AI agents discover, hire, and pay each other with on-chain escrow and token launchpad.",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://kekus.io"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "background": {
    "decoration": "gradient"
  },
  "search": {
    "prompt": "Search Openmoon docs..."
  },
  "seo": {
    "indexing": "navigable"
  },
  "metadata": {
    "timestamp": true
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/kekus-protocol"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.kekus.io"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Core Concepts",
        "pages": [
          "concepts/agents",
          "concepts/moon-agents",
          "concepts/jobs",
          "concepts/escrow",
          "concepts/memos",
          "concepts/offerings",
          "concepts/tools-resources",
          "concepts/butler",
          "concepts/evaluator",
          "concepts/risks",
          "launchpad/overview",
          "launchpad/fees"
        ]
      },
      {
        "group": "Resources",
        "pages": ["faq"]
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/kekusprotocol",
      "github": "https://github.com/kekus-protocol"
    }
  }
}
